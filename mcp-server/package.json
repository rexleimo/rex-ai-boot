{
  "name": "playwright-browser-mcp",
  "version": "1.0.0",
  "type": "module",
  "description": "Playwright MCP server for browser automation with profile and CDP support",
  "main": "dist/index.js",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "build": "node -e \"const fs=require('fs'); if (fs.rmSync) { fs.rmSync('dist',{recursive:true,force:true}); } else if (fs.existsSync('dist')) { fs.rmdirSync('dist',{recursive:true}); }\" && node scripts/with-project-node.mjs ./node_modules/typescript/bin/tsc",
    "start": "node scripts/with-project-node.mjs ./dist/index.js",
    "dev": "node scripts/with-project-node.mjs ./node_modules/tsx/dist/cli.mjs src/index.ts",
    "typecheck": "node scripts/with-project-node.mjs ./node_modules/typescript/bin/tsc --noEmit",
    "test": "node scripts/with-project-node.mjs ./node_modules/tsx/dist/cli.mjs --test tests/**/*.test.ts",
    "test:contextdb": "node scripts/with-project-node.mjs ./node_modules/tsx/dist/cli.mjs --test tests/contextdb.test.ts",
    "bench:contextdb:refs": "node scripts/with-project-node.mjs ./node_modules/tsx/dist/cli.mjs scripts/contextdb-refs-benchmark.ts",
    "bench:contextdb:refs:ci": "node scripts/with-project-node.mjs ./node_modules/tsx/dist/cli.mjs scripts/contextdb-refs-benchmark.ts --events 1200 --refs-pool 180 --queries 240 --warmup 40 --json-out test-results/contextdb-refs-bench.json",
    "bench:contextdb:refs:gate": "node scripts/with-project-node.mjs ./node_modules/tsx/dist/cli.mjs scripts/contextdb-refs-benchmark-gate.ts --input test-results/contextdb-refs-bench.json",
    "contextdb": "node scripts/with-project-node.mjs ./node_modules/tsx/dist/cli.mjs src/contextdb/cli.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.10.0",
    "playwright": "^1.58.2",
    "playwright-core": "^1.59.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
