  "workflow": {
    "step1": "接收智能内容分析的结果",
    "step2": "根据内容类型和信号，自动选择推荐策略（A/B/C）",
    "step3": "根据策略推荐风格+布局组合",
    "step4": "从预设库中匹配最接近的preset",
    "step5": "生成对应策略的详细大纲结构",
    "step6": "输出策略选择报告（包含推荐preset、风格、布局、大纲）"
  },
  "integration": {
    "前置技能": ["智能内容分析"],
    "后置技能": ["生成小红书配图", "剧本式多图生成", "publish笔记"],
    "usage_pattern": "内容生产的第二步：分析完成后，选择策略并生成大纲"
  },
  "notes": [
    "策略选择不是绝对的，用户可以手动覆盖",
    "混合策略：一个故事驱动的笔记也可以包含信息密集的知识卡片",
    "预设库应定期更新，跟上平台趋势",
    "风格×布局矩阵中的'避免'组合并非不能用，只是效果可能不理想"
  ]
