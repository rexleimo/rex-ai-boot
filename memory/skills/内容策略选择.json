{
  "skill_name": "内容策略选择",
  "description": "基于智能内容分析的结果，自动选择最优的内容表达策略（故事驱动/信息密集/视觉优先），并生成对应的大纲结构。",
  "version": "1.0.0",
  "trigger_keywords": ["策略选择", "内容策略", "大纲生成", "结构规划", "笔记结构", "storyboard"],
  "strategies": {
    "A_故事驱动": {
      "name": "Story-Driven",
      "concept": "以个人经历为主线，情感共鸣优先",
      "best_for": ["情感恋爱", "生活分享", "情绪治愈", "搞笑娱乐"],
      "structure": {
        "Hook": {
          "purpose": "抓住注意力",
          "techniques": ["悬念开场", "冲突前置", "情绪冲击", "反常识观点"],
          "example": "没想到，我和crush的故事是这样开始的..."
        },
        "Problem": {
          "purpose": "建立共鸣",
          "techniques": ["描述困境", "表达困惑", "展现矛盾", "制造代入感"],
          "example": "那段时间我特别焦虑，总觉得他不回消息就是不喜欢我"
        },
        "Discovery": {
          "purpose": "转折点",
          "techniques": ["意外发现", "朋友点拨", "自我反思", "某个瞬间的领悟"],
          "example": "直到有天闺蜜一句话点醒了我..."
        },
        "Experience": {
          "purpose": "核心体验",
          "techniques": ["详细过程", "心理变化", "互动细节", "高潮时刻"],
          "example": "我开始尝试改变，结果出乎意料..."
        },
        "Conclusion": {
          "purpose": "升华+互动引导",
          "techniques": ["感悟总结", "金句收尾", "提问互动", "CTA引导"],
          "example": "所以姐妹们，勇敢一点真的会有惊喜。你们有过类似的经历吗？"
        }
      },
      "typical_length": "800-1500字",
      "image_count": "4-6张",
      "image_layout": "balanced/flow"
    },
    "B_信息密集": {
      "name": "Information-Dense",
      "concept": "价值优先，高效信息交付",
      "best_for": ["干货教程", "避雷指南", "清单合集", "知识科普"],
      "structure": {
        "Core_Conclusion": {
          "purpose": "先给答案",
          "techniques": ["核心结论前置", "一句话总结", "数字冲击", "利益承诺"],
          "example": "大学四年，这5个道理越早明白越好"
        },
        "Info_Card": {
          "purpose": "分点展开",
          "techniques": ["编号列表", "小标题清晰", "每点独立完整", "层层递进"],
          "example": "1. 学业≠全部 2. 社交要筛选 3. 实习要趁早..."
        },
        "Pros_Cons": {
          "purpose": "增加可信度",
          "techniques": ["正反对比", "常见误区", "真实案例", "数据支撑"],
          "example": "很多人觉得A很重要，但其实B才是关键..."
        },
        "Recommendation": {
          "purpose": " actionable建议",
          "techniques": ["具体步骤", "工具推荐", "资源分享", "执行清单"],
          "example": "如果你也想尝试，可以按照这个顺序：第一步..."
        },
        "CTA": {
          "purpose": "留存互动",
          "techniques": ["收藏提醒", "关注引导", "评论区提问", "后续预告"],
          "example": "建议收藏，下次迷茫时拿出来看看。你还想知道什么？"
        }
      },
      "typical_length": "600-1200字",
      "image_count": "3-5张",
      "image_layout": "dense/list"
    },
    "C_视觉优先": {
      "name": "Visual-First",
      "concept": "视觉冲击为核心，文字辅助",
      "best_for": ["穿搭分享", "美食探店", "旅行打卡", "好物展示", "高颜值产品"],
      "structure": {
        "Hero_Image": {
          "purpose": "视觉震撼",
          "techniques": ["最佳角度", "氛围感", "色彩冲击", "场景代入"],
          "example": "封面：全身穿搭look，背景是网红咖啡店"
        },
        "Detail_Shots": {
          "purpose": "展示细节",
          "techniques": ["特写镜头", "质感呈现", "细节放大", "多角度展示"],
          "example": "细节图：配饰搭配、面料质感、颜色对比"
        },
        "Lifestyle_Scene": {
          "purpose": "场景代入",
          "techniques": ["使用场景", "氛围营造", "故事感", "生活方式"],
          "example": "场景图：和朋友聚会/日常通勤/周末出游"
        },
        "CTA": {
          "purpose": "互动转化",
          "techniques": ["购买链接", "店铺地址", "搭配建议", "互动提问"],
          "example": "全身链接在评论区，喜欢的姐妹自取～"
        }
      },
      "typical_length": "300-600字",
      "image_count": "6-9张",
      "image_layout": "sparse/balanced"
    }
  },
  "auto_selection": {
    "description": "基于内容信号自动匹配最佳策略",
    "rules": [
      {
        "signals": ["故事", "经历", "感受", "心情", "某天", "突然", "没想到", "后来"],
        "strategy": "A_故事驱动",
        "confidence_boost": 0.3
      },
      {
        "signals": ["攻略", "教程", "步骤", "方法", "技巧", "避雷", "清单", "合集", "必看", "干货"],
        "strategy": "B_信息密集",
        "confidence_boost": 0.3
      },
      {
        "signals": ["穿搭", "美食", "旅行", "探店", "好物", "开箱", "look", "打卡", "颜值"],
        "strategy": "C_视觉优先",
        "confidence_boost": 0.3
      }
    ],
    "fallback": "如果信号不明确，优先选择B_信息密集（普适性最强）",
    "manual_override": "用户可以通过--strategy A/B/C手动指定策略"
  },
