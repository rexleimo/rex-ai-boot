{
  "skill_name": "智能内容分析",
  "description": "在生成/发布小红书笔记前，对内容进行深度AI分析，识别内容类型、评估爆款潜力、规划视觉策略。是AIOS内容生产流程的'智力大脑'。",
  "version": "1.0.0",
  "trigger_keywords": ["分析内容", "内容诊断", "笔记分析", "爆款潜力", "内容优化", "pre-analysis"],
  "analysis_framework": {
    "step1_内容类型识别": {
      "description": "基于标题和正文前200字，识别内容所属类型",
      "types": {
        "情感恋爱": {
          "signals": ["男朋友", "crush", "情侣", "恋爱", "暧昧", "约会", "心动", "分手", "复合", "暗恋"],
          "audience": "18-28岁女性，情感需求强烈",
          "engagement_pattern": "评论互动率高，易引发共鸣"
        },
        "情绪治愈": {
          "signals": ["焦虑", "治愈", "放松", "温暖", "孤独", "开心", "难过", "自愈", "情绪", "解压"],
          "audience": "压力大的年轻人，寻求情绪出口",
          "engagement_pattern": "收藏率高，转发分享多"
        },
        "干货教程": {
          "signals": ["教程", "攻略", "技巧", "方法", "步骤", "指南", "干货", "必看", "避雷", "省钱"],
          "audience": "有明确需求的实用主义用户",
          "engagement_pattern": "收藏率极高，长尾流量好"
        },
        "生活分享": {
          "signals": ["日常", "vlog", "好物", "测评", "推荐", "开箱", "穿搭", "美食", "旅行", "宿舍"],
          "audience": "兴趣广泛的生活爱好者",
          "engagement_pattern": "点赞率高，关注转化好"
        },
        "态度宣言": {
          "signals": ["人间清醒", "独立", "自由", "做自己", "拒绝", "不内耗", "格局", "觉醒", "认知"],
          "audience": "追求自我认同的年轻女性",
          "engagement_pattern": "转发率高，易形成话题"
        },
        "搞笑娱乐": {
          "signals": ["搞笑", "梗", "段子", "笑死", "离谱", "神操作", "脑洞", "吐槽", "阴阳", "整活"],
          "audience": "泛娱乐用户，全年龄段",
          "engagement_pattern": "点赞+评论双高，传播性强"
        }
      }
    },
    "step2_Hook潜力评估": {
      "description": "评估标题和开头的吸引力，满分10分",
      "scoring_dimensions": {
        "悬念感": {
          "high_signals": ["问号", "省略号", "竟然", "居然", "没想到", "原来", "才发现", "真相"],
          "score_weight": 0.25
        },
        "情绪张力": {
          "high_signals": ["感叹号", "破防", "泪目", "救命", "绝了", "炸裂", "太", "真的"],
          "score_weight": 0.25
        },
        "共鸣度": {
          "high_signals": ["谁懂", "我也是", "有没有", "是不是", "同款", " common", "大家都"],
          "score_weight": 0.25
        },
        "实用性": {
          "high_signals": ["秒变", "直接", "立刻", "马上", "高效", "简单", "懒人", "小白"],
          "score_weight": 0.15
        },
        "数字冲击": {
          "high_signals": ["数字+个/种/条/件/招/步", "排名", "TOP", "清单", "合集"],
          "score_weight": 0.10
        }
      },
      "score_interpretation": {
        "8-10": "爆款潜力极高，建议重点投入",
        "6-7": "有潜力，可通过优化标题/开头提升",
        "4-5": "普通水平，需要较大改进",
        "1-3": "缺乏吸引力，建议重新构思"
      }
    },
    "step3_受众匹配分析": {
      "description": "分析内容与目标受众的匹配度",
      "dimensions": {
        "年龄匹配": "内容语言、话题、场景是否符合目标年龄段",
        "性别匹配": "内容是否精准触达女性用户兴趣点",
        "场景匹配": "内容是否对应用户真实生活场景",
        "需求匹配": "内容是否解决用户的实际问题或情感需求"
      },
      "output": {
        "primary_audience": "主要受众画像",
        "secondary_audience": "次要受众画像",
        "match_score": "匹配度评分 1-10",
        "recommendation": "扩大受众或精准定位的建议"
      }
    },
    "step4_视觉机会地图": {
      "description": "识别内容中哪些段落/观点最适合配图",
      "visual_opportunities": {
        "封面图": {
          "importance": "极高",
          "purpose": "第一印象，决定点击率",
          "best_practices": ["高颜值", "有情绪", "与标题呼应", "留白适合叠加文字"]
        },
        "情绪高点图": {
          "importance": "高",
          "purpose": "强化情感共鸣",
          "triggers": ["情绪转折处", "感人瞬间", "惊喜发现"]
        },
        "信息图": {
          "importance": "中-高",
          "purpose": "将复杂信息可视化",
          "triggers": ["步骤/流程", "对比/排行", "数据/统计", "清单/合集"]
        },
        "场景图": {
          "importance": "中",
          "purpose": "增强代入感",
          "triggers": ["特定场景描述", "生活方式展示", "产品使用场景"]
        }
      }
    },
    "step5_互动潜力预测": {
      "description": "预测笔记的互动表现",
      "predictions": {
        "点赞潜力": "基于情绪价值和视觉吸引力的评估",
        "收藏潜力": "基于实用性和信息密度的评估",
        "评论潜力": "基于话题性和争议度的评估",
        "转发潜力": "基于社交货币和态度表达的评估"
      },
      "optimization_tips": {
        "提升点赞": "增加情绪高点，优化封面颜值",
        "提升收藏": "增加干货密度，使用信息图",
        "提升评论": "在结尾抛出问题，引导用户分享经历",
        "提升转发": "增加态度表达，让用户觉得'说出了我想说的话'"
      }
    }
  },
  "workflow": {
    "step1": "接收内容（标题+正文）",
    "step2": "运行内容类型识别，输出类型和置信度",
    "step3": "运行Hook潜力评估，输出评分和改进建议",
    "step4": "运接受众匹配分析，输出受众画像",
    "step5": "运行视觉机会地图，输出配图规划",
    "step6": "运行互动潜力预测，输出优化建议",
    "step7": "汇总为analysis.md格式的结构化报告"
  },
  "output_format": {
    "analysis_report": {
      "content_type": "识别出的内容类型及置信度",
      "hook_score": "Hook潜力评分 1-10",
      "hook_analysis": "各维度得分详情",
      "audience": {
        "primary": "主要受众",
        "match_score": "匹配度"
      },
      "visual_plan": {
        "cover": "封面图建议",
        "content_images": [
          {"position": "段落位置", "type": "图片类型", "purpose": "配图目的"}
        ]
      },
      "engagement_prediction": {
        "like": "高/中/低",
        "save": "高/中/低",
        "comment": "高/中/低",
        "share": "高/中/低"
      },
      "optimization_suggestions": ["具体优化建议列表"]
    }
  },
  "integration": {
    "前置技能": ["内容选题规划", "爆款内容分析"],
    "后置技能": ["内容策略选择", "生成小红书配图", "剧本式多图生成"],
    "usage_pattern": "内容生产流程的第一步，所有笔记在创作前/后都应运行此分析"
  },
  "notes": [
    "分析结果存入memory/history/用于后续训练优化",
    "与爆款内容分析.json联动，用历史数据校准预测模型",
    "分析框架应定期根据平台趋势更新信号词库"
  ]
}
