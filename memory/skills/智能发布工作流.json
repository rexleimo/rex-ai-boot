{
  "skill_name": "智能发布工作流",
  "description": "小红书笔记智能发布系统。包含发布前检查、Cookie验证、错误诊断、自动重试、定时发布、Dry-run预览等AI智力功能。",
  "version": "1.0.0",
  "trigger_keywords": ["发布笔记", "publish", "发小红书", "上传笔记", "定时发布", "dry-run", "预览发布"],
  "platform": "creator.xiaohongshu.com",
  "pre_publish_checks": {
    "description": "发布前的智能检查清单",
    "checks": {
      "内容质量检查": {
        "title_length": {"min": 5, "max": 20, "warning": "标题建议5-20字"},
        "content_length": {"min": 50, "warning": "正文建议至少50字"},
        "image_count": {"min": 1, "max": 18, "warning": "建议1-18张图"},
        "has_tags": {"required": true, "warning": "建议添加3-5个话题标签"},
        "sensitive_words": {"check": true, "source": "memory/knowledge/敏感词库.json"}
      },
      "账号状态检查": {
        "login_status": "检查是否已登录",
        "cookie_validity": "检查Cookie是否过期",
        "daily_quota": {"max_posts": 3, "warning": "今日已发布X篇，还可发布Y篇"}
      },
      "发布时间检查": {
        "peak_hours": ["7:00-9:00", "12:00-14:00", "18:00-22:00"],
        "recommendation": "建议在高峰期发布以获得更多曝光"
      }
    }
  },
  "cookie_management": {
    "description": "智能Cookie验证和错误诊断",
    "validation": {
      "required_fields": ["a1", "web_session"],
      "check_method": "解析Cookie字符串，检查必需字段",
      "warning_if_missing": "Cookie可能不完整，可能导致签名失败"
    },
    "error_diagnosis": {
      "签名错误": {
        "symptoms": ["sign", "signature", "签名失败"],
        "causes": ["Cookie缺少a1字段", "Cookie已过期", "签名算法不匹配"],
        "solutions": [
          "1. 确保Cookie包含有效的a1和web_session字段",
          "2. 重新获取Cookie（浏览器登录→F12→Network→复制Cookie）",
          "3. 检查系统时间是否正确"
        ]
      },
      "Cookie过期": {
        "symptoms": ["cookie", "expired", "登录失效", "未登录"],
        "causes": ["Cookie有效期到期", "账号在其他地方登录", "平台强制登出"],
        "solutions": [
          "1. 重新登录小红书网页版",
          "2. 获取新的Cookie字符串",
          "3. 更新到.env或配置文件中"
        ]
      },
      "发布频率限制": {
        "symptoms": ["频繁", "限制", "请稍后再试", "操作太频繁"],
        "causes": ["短时间内发布过多", "触发平台风控"],
        "solutions": [
          "1. 等待30分钟后再试",
          "2. 降低发布频率（每天不超过3篇）",
          "3. 增加操作间隔（5-30秒随机延迟）"
        ]
      },
      "内容审核": {
        "symptoms": ["审核", "违规", "敏感", "不通过"],
        "causes": ["内容包含敏感词", "图片违规", "标题夸张"],
        "solutions": [
          "1. 使用敏感词库检查内容",
          "2. 修改标题避免夸张表述",
          "3. 更换可能违规的图片"
        ]
      }
    }
  },
  "publish_modes": {
    "immediate": {
      "name": "立即发布",
      "description": "检查通过后立即发布",
      "workflow": [
        "1. 运行发布前检查清单",
        "2. 验证Cookie有效性",
        "3. 导航到发布页面",
        "4. 填充标题、正文、图片、标签",
        "5. 选择可见范围（公开/私密）",
        "6. 点击发布",
        "7. 等待发布结果",
        "8. 记录到history/"
      ]
    },
    "dry_run": {
      "name": "预览模式",
      "description": "仅验证，不实际发布",
      "workflow": [
        "1. 运行发布前检查清单",
        "2. 验证Cookie有效性",
        "3. 模拟填充内容（不点击发布）",
        "4. 生成预览截图",
        "5. 输出验证报告"
      ],
      "use_case": "发布前预览效果，检查排版和内容"
    },
    "scheduled": {
      "name": "定时发布",
      "description": "在指定时间自动发布",
      "workflow": [
        "1. 接收发布时间（格式：YYYY-MM-DD HH:MM:SS）",
        "2. 验证时间是否有效（必须是未来时间）",
        "3. 保存待发布内容到 tasks/pending/",
        "4. 设置定时任务",
        "5. 到时间后自动执行发布流程"
      ],
      "storage_format": {
        "file": "tasks/pending/scheduled-{timestamp}.json",
        "content": ["title", "content", "images", "tags", "scheduled_time", "visibility"]
      }
    }
  },
  "visibility_options": {
    "private": {
      "name": "仅自己可见",
      "description": "发布后可预览，确认无误后再改为公开",
      "recommended": true,
      "use_case": "首次发布新账号、测试内容、预览检查"
    },
    "public": {
      "name": "公开发布",
      "description": "所有用户可见",
      "recommended": false,
      "use_case": "确认内容无误后的正式发布"
    }
  },
  "auto_retry": {
    "description": "发布失败的自动重试机制",
    "enabled": true,
    "max_attempts": 3,
    "retry_interval_seconds": 30,
    "retry_strategy": {
      "attempt1": "直接重试",
      "attempt2": "刷新Cookie后重试",
      "attempt3": "延长间隔后重试",
      "after_max": "报告失败原因，建议人工处理"
    }
  },
  "browser_workflow": {
    "step1_navigate": {
      "action": "导航到创作平台",
      "url": "https://creator.xiaohongshu.com/creator/post"
    },
    "step2_login_check": {
      "action": "检查登录状态",
      "method": "检查页面是否出现登录框或需要扫码",
      "if_not_login": "提示用户扫码登录后继续"
    },
    "step3_fill_title": {
      "action": "填写标题",
      "selector": ".title-input",
      "validation": "标题5-20字，不含敏感词"
    },
    "step4_fill_content": {
      "action": "填写正文",
      "selector": ".content-editor",
      "validation": "正文至少50字，分段清晰"
    },
    "step5_upload_images": {
      "action": "上传图片",
      "selector": "上传图片按钮",
      "order": "按顺序上传（封面在首张）",
      "max": "最多18张"
    },
    "step6_add_tags": {
      "action": "添加话题标签",
      "count": "3-5个",
      "source": "热门话题.json + 内容主题"
    },
    "step7_set_visibility": {
      "action": "设置可见范围",
      "default": "仅自己可见（可从extend-preferences.json修改）"
    },
    "step8_publish": {
      "action": "点击发布按钮",
      "selector": ".publish-btn",
      "wait_for": "发布成功提示或页面跳转"
    },
    "step9_record": {
      "action": "记录发布结果",
      "save_to": "memory/history/操作记录模板.json",
      "include": ["发布时间", "标题", "类型", "图片数", "状态"]
    }
  },
  "post_publish": {
    "description": "发布后的智能跟进",
    "actions": {
      "数据追踪": "记录发布时间和初始数据",
      "定时检查": "建议24小时后检查数据表现",
      "互动提醒": "如有评论，建议及时回复",
      "效果分析": "将数据反馈到爆款内容分析.json用于优化"
    }
  },
  "integration": {
    "前置技能": ["智能内容分析", "内容策略选择", "生成小红书配图"],
    "配置依赖": ["config/extend-preferences.json"],
    "知识依赖": ["memory/knowledge/敏感词库.json", "memory/knowledge/热门话题.json"]
  },
  "notes": [
    "发布前务必运行dry-run预览，尤其是新账号",
    "Cookie安全：不要把Cookie提交到Git或共享",
    "发布频率：避免短时间内高频发布，每天最多3篇",
    "操作间隔：随机5-30秒，模拟人类行为",
    "自动重试：失败后最多重试3次，仍失败则人工处理",
    "定时发布：需要系统支持任务调度（如cron）"
  ]
}
