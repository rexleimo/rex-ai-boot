  "generation_workflow": {
    "step1_preparation": {
      "action": "接收内容策略选择的输出（策略+风格+布局+配色）",
      "input": ["strategy", "style", "layout", "palette", "preset", "image_count"]
    },
    "step2_prompt_creation": {
      "action": "为每张图片创建提示词文件",
      "rules": [
        "封面图：强调视觉冲击力和标题呼应",
        "内容图：与封面保持风格一致（锚定链）",
        "结尾图：CTA引导或总结",
        "每张提示词保存到prompts/NN-{type}-{slug}.md"
      ]
    },
    "step3_anchor_generation": {
      "action": "生成封面图（建立锚点）",
      "tool": "baoyu-xhs-images 或 即梦AI",
      "special": "不使用参考图，建立风格基准",
      "save": "保存封面图路径到anchor_image"
    },
    "step4_batch_generation": {
      "action": "批量并行生成内容图",
      "parallel": "最多3张同时生成",
      "anchor": "每张图的prompt都包含锚定描述",
      "ref": "在即梦AI中使用anchor_image作为风格参考"
    },
    "step5_final_generation": {
      "action": "生成结尾图",
      "anchor": "同样使用锚定描述和参考图"
    },
    "step6_quality_check": {
      "action": "质量检查",
      "checks": [
        "系列图风格一致性",
        "图片清晰度",
        "是否有不需要的文字",
        "配色是否协调"
      ]
    },
    "step7_save": {
      "action": "保存所有图片到aios/images/",
      "naming": "{topic}_{type}_{序号}.png",
      "backup": "覆盖前自动重命名备份"
    }
  },
  "prompt_templates": {
    "cover_default": "[风格描述]背景，[氛围描述]，[主体描述]，[光线/配色]，适合社交媒体封面，无文字，3:4竖版",
    "content_default": "与参考图保持一致的[风格/配色/光线]，[具体画面内容]，[情绪氛围]，[构图描述]，无文字，3:4竖版",
    "ending_default": "与参考图保持一致的[风格/配色/光线]，[总结/CTA画面]，[情绪氛围]，无文字，3:4竖版"
  },
  "aspect_ratios": {
    "3:4": "小红书竖版图文推荐（最佳）",
    "1:1": "小红书方形图文",
    "16:9": "横版视频封面",
    "9:16": "竖版视频封面"
  },
  "output": {
    "directory": "aios/images/",
    "prompt_directory": "aios/images/prompts/",
    "naming_pattern": "{topic}_{type}_{序号}.png",
    "backup_rule": "覆盖前自动重命名为{name}-backup-{timestamp}.{ext}"
  },
  "error_handling": {
    "策略拦截": "自动改写为中性提示词并重试1次",
    "生成失败": "重试3次后跳过，记录原因",
    "风格不一致": "重新生成或使用更强的锚定描述",
    "超时": "刷新页面后重试1次"
  },
  "integration": {
    "前置技能": ["智能内容分析", "内容策略选择"],
    "后置技能": ["publish笔记", "剧本式多图生成"],
    "related_files": ["config/extend-preferences.json"]
  },
  "notes": [
    "v2.0重大升级：增加AI智能分析、锚定链、批量并行、提示词文件优先",
    "即梦AI对某些词汇有限制，避免使用敏感词",
    "推荐使用3:4比例获得最佳显示效果",
    "不同主题使用不同配色，保持内容一致性",
    "批量生成时控制并发数量，避免触发平台限制",
    "提示词文件是重要资产，方便后续修改和复现"
  ]
}
