  "auto_mapping": {
    "description": "内容类型到风格/布局/配色的自动映射",
    "mappings": {
      "情感恋爱": {"style": "cute", "layout": "balanced", "palette": "default", "reason": "甜美可爱风格最符合小红书女性用户审美"},
      "情绪治愈": {"style": "warm", "layout": "balanced", "palette": "warm", "reason": "温暖风格增强治愈感"},
      "干货教程": {"style": "notion", "layout": "dense", "palette": "default", "reason": "知识风适合干货内容，信息密集型布局"},
      "生活分享": {"style": "fresh", "layout": "balanced", "palette": "default", "reason": "清新风格适合日常分享"},
