{
  "skill_name": "生成小红书配图",
  "description": "AI智能配图生成系统。基于内容分析自动推荐风格/布局/配色，支持图片锚定链保证视觉一致性，批量并行生成，提示词文件优先。是AIOS内容生产流程的核心视觉引擎。",
  "version": "2.0.0",
  "trigger_keywords": ["生成图片", "做张图", "配图", "封面图", "即梦", "AI配图", "小红书配图", "出图", "画图"],
  "platform": "jimeng.jianying.com / tongyi / multi-provider",
  "primary_tool": "baoyu-xhs-images",
  "fallback_tools": ["jimeng", "tongyi", "seedream"],
  "ai_intelligence_features": {
    "auto_selection": {
      "description": "基于内容信号自动匹配风格/布局/配色",
      "enabled": true,
      "source": "内容策略选择.json 的输出",
      "inputs": ["content_type", "strategy", "audience", "hook_score"]
    },
    "anchor_chain": {
      "description": "图片1锚定链：封面作为视觉锚点，后续图片以封面为参考保证一致性",
      "enabled": true,
      "workflow": [
        "1. 生成封面图（Image 1），保存为anchor_image",
        "2. 提取封面风格关键词（配色、光线、画风、氛围）",
        "3. 后续每张图的prompt前缀统一加入锚定描述",
        "4. 在即梦AI中使用参考图功能上传anchor_image作为风格参考",
        "5. 系列图完成后检查一致性"
      ],
      "anchor_prompt_template": "与参考图保持一致的[风格/配色/光线]，[具体画面内容]，无文字",
      "consistency_check": "检查系列图的角色形象、配色方案、画风是否统一"
    },
    "batch_generation": {
      "description": "批量并行生成多张图片",
      "enabled": true,
      "max_parallel": 3,
      "strategy": "封面先生成（建立锚点），内容图并行生成（带锚定描述），结尾图最后生成",
      "retry_policy": {
        "max_attempts": 3,
        "on_failure": "自动改写提示词并重试，仍失败则跳过该图并记录原因"
      }
    },
    "prompt_file_first": {
      "description": "提示词文件优先原则：每张图的完整提示词先保存到文件，再调用生成",
      "enabled": true,
      "file_format": "prompts/NN-{type}-{slug}.md",
      "content": {
        "frontmatter": "YAML格式，包含type, style, layout, palette, anchor_ref",
        "body": "完整的AI生成提示词"
      },
      "purpose": "可重现性记录，方便修改和重新生成"
    }
  },
